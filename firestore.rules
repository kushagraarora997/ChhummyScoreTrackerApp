rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /families/{familyId}/{document=**} {
      // Only allow access to exactly 6-character room codes.
      // Blocks random/garbage keys while preserving the family-trust model.
      allow read, write: if familyId.size() == 6;
    }
  }
}
